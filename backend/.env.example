# ─── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ─────────────────────────────────────────────────
# STEP 1: Go to https://cloud.mongodb.com → your cluster → Connect → Drivers
# STEP 2: Copy your connection string and replace below
# STEP 3: Go to Network Access → Add IP → Allow from Anywhere (0.0.0.0/0)
#
# Format: mongodb+srv://USERNAME:PASSWORD@cluster0.XXXXX.mongodb.net/resume-builder
# Example: mongodb+srv://john:mypass123@cluster0.ab1cd.mongodb.net/resume-builder?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.YOURCLUSTER.mongodb.net/resume-builder?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────────────────
# Use any long random string (min 32 chars)
JWT_SECRET=change_this_to_a_long_random_secret_string_min32chars
JWT_EXPIRES_IN=7d

# ─── OpenAI ────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
# App works without this, but AI features will show error
OPENAI_API_KEY=sk-your-openai-api-key-here

# ─── Frontend URL (CORS) ───────────────────────────────────────────
CLIENT_URL=http://localhost:3000
